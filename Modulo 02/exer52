


num = int(input("Digite um numero :"))
contador = 0
print() 

for i in range(1,num+1):
    
    if num % i == 0:
        
        print(f"\033[0;31m{i}\033[m", end=',')
        contador  += 1 
        
    else :
        
        print(f"\033[0;34m{i}\033[m", end=',')
        
print()
print(f"O numero escolhido foi {num}\nEle foi divisivel {contador}")

if contador == 2 :
    print("Esse numero é PRIMO")
    
else:
    print("Esse numero não é primo")